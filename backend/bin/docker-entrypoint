#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ] && [ -f /usr/lib/*/libjemalloc.so.2 ]; then
  export LD_PRELOAD="$(echo /usr/lib/*/libjemalloc.so.2)"
fi

# Docker can leave a stale PID file behind across restarts when /rails is mounted.
rm -f /rails/tmp/pids/server.pid

# If running the rails server then prepare the database and seed only once.
if { [ "${1}" = "./bin/rails" ] || [ "${1}" = "rails" ]; } && [ "${2}" = "server" ]; then
  ./bin/rails db:migrate

  if ! ./bin/rails runner "exit(Expense.exists? ? 0 : 1)"; then
    ./bin/rails db:seed
  fi
fi

exec "${@}"
